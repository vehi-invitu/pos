<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings_view_form_scan" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.scan</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='pos_other_devices']" position="after">
                <setting
                    id="pos_scan_server"
                    string="Scan Server"
                    help="enter the URL of you scan server"
                >
                    <field name="pos_is_scan_server" />
                    <div class="content-group" invisible="not pos_is_scan_server">
                        <field
                            name="pos_scan_server_url"
                            placeholder="http://localhost:5555"
                        />
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
