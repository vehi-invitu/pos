<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="res_config_settings_check_split_invoices" model="ir.ui.view">
        <field name="name">res.config.settings.check.split.invoices</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="100" />
        <field name="inherit_id" ref="base.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@id='invoicing_settings']" position="inside">
                <setting help="Your company needs to check their splitting invoices ?">
                    <field name="splitting_invoices_review" />
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
